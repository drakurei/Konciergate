# --- Konciergate — variables d'environnement ---

# URL canonique du site (sans slash final). Utilisée pour SEO, sitemap, Open Graph.
NEXT_PUBLIC_SITE_URL=https://www.konciergate.com

# Resend — formulaire de contact (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# Adresse expéditrice vérifiée dans Resend (domaine validé)
CONTACT_FROM_EMAIL=contact@konciergate.com

# Adresse de réception des demandes de contact
CONTACT_TO_EMAIL=konciergate@gmail.com
